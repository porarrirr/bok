<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="P2PAudio.Windows.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#F4F6F9" />
                    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#FBFCFE" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="AppSurfaceSubtleBrush" Color="#F0F3F7" />
                    <SolidColorBrush x:Key="AppChromeStrokeBrush" Color="#D5DCE5" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#111418" />
                    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#161A1F" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#1B2026" />
                    <SolidColorBrush x:Key="AppSurfaceSubtleBrush" Color="#14181D" />
                    <SolidColorBrush x:Key="AppChromeStrokeBrush" Color="#2D343D" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#F4F6F9" />
                    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#FBFCFE" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="AppSurfaceSubtleBrush" Color="#F0F3F7" />
                    <SolidColorBrush x:Key="AppChromeStrokeBrush" Color="#D5DCE5" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="SenderAccentBrush" Color="#4D8DFF" />
            <SolidColorBrush x:Key="SenderAccentMutedBrush" Color="#174D8DFF" />
            <SolidColorBrush x:Key="ListenerAccentBrush" Color="#E59A3B" />
            <SolidColorBrush x:Key="ListenerAccentMutedBrush" Color="#18E59A3B" />

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppChromeStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="24" />
            </Style>

            <Style x:Key="InsetCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppSurfaceSubtleBrush}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppChromeStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="CodeValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="Consolas" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
