<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="P2PAudio.Windows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="音声リンク (Windows)">

    <Grid Background="{ThemeResource AppShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{ThemeResource AppHeaderBackgroundBrush}"
            BorderBrush="{ThemeResource AppChromeStrokeBrush}"
            BorderThickness="0,0,0,1"
            Padding="32,16,32,14">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock
                        x:Name="AppTitleTextBlock"
                        Text="音声リンク"
                        FontSize="28"
                        FontWeight="SemiBold" />
                    <TextBlock
                        Text="Windows と Android を直接つなぐ音声共有ワークスペース"
                        Style="{StaticResource BodyTextStyle}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <Border
                        Style="{StaticResource InsetCardStyle}"
                        Padding="12,8">
                        <StackPanel Spacing="2" MaxWidth="360">
                            <TextBlock
                                Text="{x:Bind ViewModel.TransportModeLabel, Mode=OneWay}"
                                Style="{StaticResource MetricLabelTextStyle}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.BackendLabel, Mode=OneWay}"
                                Style="{StaticResource BodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Button
                        Content="接続を終了"
                        Click="OnStopClick"
                        IsEnabled="{x:Bind ViewModel.CanStop, Mode=OneWay}"
                        Padding="18,10"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            Padding="32,24,32,32"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Spacing="20"
                MaxWidth="1120">

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        x:Name="StatusHeroCard"
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource SectionCardStyle}"
                        Padding="0">
                        <Grid>
                            <Border
                                Width="6"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource AppChromeStrokeBrush}"
                                CornerRadius="20,0,0,20" />

                            <Grid Padding="28,26">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="14">
                                    <TextBlock
                                        Text="接続ステータス"
                                        Style="{StaticResource EyebrowTextStyle}" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="52"
                                            Height="52"
                                            CornerRadius="16"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            VerticalAlignment="Top">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.StreamStateIndicator, Mode=OneWay}"
                                                FontSize="24"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="6">
                                            <TextBlock
                                                x:Name="StreamStateText"
                                                Text="{x:Bind ViewModel.StreamStateLabel, Mode=OneWay}"
                                                FontSize="30"
                                                FontWeight="SemiBold"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Text="{x:Bind ViewModel.RecommendedAction, Mode=OneWay}"
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                                Style="{StaticResource BodyTextStyle}" />
                                        </StackPanel>

                                        <Border
                                            Grid.Column="2"
                                            Style="{StaticResource InsetCardStyle}"
                                            Padding="12,8"
                                            VerticalAlignment="Top">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.StepProgressLabel, Mode=OneWay}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextWrapping="Wrap" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Spacing="8">
                                    <ProgressBar
                                        Minimum="0"
                                        Maximum="3"
                                        Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                                        Height="6" />
                                    <TextBlock
                                        Text="必要な手順だけが下に表示されます。進行中はこのステータスが最優先で更新されます。"
                                        Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>

                                <Border
                                    x:Name="StatusFailurePanel"
                                    Grid.Row="2"
                                    Visibility="Collapsed"
                                    Style="{StaticResource InsetCardStyle}"
                                    Margin="0,18,0,0"
                                    BorderBrush="{ThemeResource SystemFillColorCriticalBrush}">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="対応が必要です"
                                            Style="{StaticResource MetricLabelTextStyle}"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        <TextBlock
                                            Text="{x:Bind ViewModel.FailureHintLabel, Mode=OneWay}"
                                            FontSize="13"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Text="{x:Bind ViewModel.FailureCodeLabel, Mode=OneWay}"
                                            FontSize="12"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource SectionCardStyle}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="接続サマリー"
                                    Style="{StaticResource EyebrowTextStyle}" />
                                <TextBlock
                                    Text="現在の構成"
                                    FontSize="22"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="転送方式とネットワークの見え方を、ここでまとめて確認できます。"
                                    Style="{StaticResource BodyTextStyle}" />
                            </StackPanel>

                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="転送" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.TransportModeLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="接続モジュール" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.BackendLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="経路" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.NetworkPathLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="候補" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CandidateCountLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="選択中" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedCandidatePairLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="音声" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.AudioStreamSummaryLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="統計" Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.AudioHealthLabel, Mode=OneWay}" Style="{StaticResource MetricValueTextStyle}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <InfoBar
                    x:Name="TransientInfoBar"
                    IsOpen="False"
                    Severity="Success"
                    IsClosable="True" />

                <Border
                    x:Name="EntryCard"
                    Style="{StaticResource SectionCardStyle}">
                    <Grid ColumnSpacing="24" RowSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="セットアップ"
                                    Style="{StaticResource EyebrowTextStyle}" />
                                <TextBlock
                                    Text="転送モードと役割を選ぶ"
                                    Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock
                                    Text="最初に方式を決めると、このPCで必要な手順だけが表示されます。"
                                    Style="{StaticResource BodyTextStyle}" />
                            </StackPanel>

                            <Border Style="{StaticResource InsetCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Text="転送モード"
                                        Style="{StaticResource MetricLabelTextStyle}" />
                                    <ComboBox
                                        x:Name="TransportModeComboBox"
                                        SelectionChanged="OnTransportModeSelectionChanged"
                                        SelectedIndex="{x:Bind ViewModel.SelectedTransportModeIndex, Mode=OneWay}">
                                        <ComboBoxItem Content="WebRTC" />
                                        <ComboBoxItem Content="UDP + Opus" />
                                    </ComboBox>
                                    <TextBlock
                                        Text="{x:Bind ViewModel.TransportModeDescription, Mode=OneWay}"
                                        Style="{StaticResource BodyTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border
                                x:Name="UdpOpusFrameDurationPanel"
                                Visibility="Collapsed"
                                Style="{StaticResource InsetCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Text="UDP + Opus 詳細"
                                        Style="{StaticResource MetricLabelTextStyle}" />

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="Opus フレーム長"
                                            Style="{StaticResource MetricLabelTextStyle}" />
                                        <ComboBox
                                            x:Name="UdpOpusFrameDurationComboBox"
                                            SelectionChanged="OnUdpOpusFrameDurationSelectionChanged"
                                            SelectedIndex="{x:Bind ViewModel.SelectedUdpOpusFrameDurationIndex, Mode=OneWay}"
                                            IsEnabled="{x:Bind ViewModel.CanConfigureUdpOpusFrameDuration, Mode=OneWay}">
                                            <ComboBoxItem Content="5 ms" />
                                            <ComboBoxItem Content="10 ms" />
                                            <ComboBoxItem Content="20 ms" />
                                            <ComboBoxItem Content="40 ms" />
                                            <ComboBoxItem Content="60 ms" />
                                        </ComboBox>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.UdpOpusFrameDurationDescription, Mode=OneWay}"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="Opus application"
                                            Style="{StaticResource MetricLabelTextStyle}" />
                                        <ComboBox
                                            x:Name="UdpOpusApplicationComboBox"
                                            SelectionChanged="OnUdpOpusApplicationSelectionChanged"
                                            SelectedIndex="{x:Bind ViewModel.SelectedUdpOpusApplicationIndex, Mode=OneWay}"
                                            IsEnabled="{x:Bind ViewModel.CanConfigureUdpOpusApplication, Mode=OneWay}">
                                            <ComboBoxItem Content="RESTRICTED_LOWDELAY" />
                                            <ComboBoxItem Content="AUDIO" />
                                        </ComboBox>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.UdpOpusApplicationDescription, Mode=OneWay}"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border
                                x:Name="UdpReceiveLatencyPanel"
                                Visibility="Collapsed"
                                Style="{StaticResource InsetCardStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Text="UDP + Opus 受信"
                                        Style="{StaticResource MetricLabelTextStyle}" />
                                    <StackPanel Spacing="6">
                                        <TextBlock
                                            Text="受信バッファ"
                                            Style="{StaticResource MetricLabelTextStyle}" />
                                        <ComboBox
                                            x:Name="UdpReceiveLatencyComboBox"
                                            SelectionChanged="OnUdpReceiveLatencySelectionChanged"
                                            SelectedIndex="{x:Bind ViewModel.SelectedUdpReceiveLatencyIndex, Mode=OneWay}"
                                            IsEnabled="{x:Bind ViewModel.CanConfigureUdpReceiveLatency, Mode=OneWay}">
                                            <ComboBoxItem Content="20 ms" />
                                            <ComboBoxItem Content="50 ms" />
                                            <ComboBoxItem Content="100 ms" />
                                            <ComboBoxItem Content="300 ms" />
                                        </ComboBox>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.UdpReceiveLatencyDescription, Mode=OneWay}"
                                            Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="12">
                            <TextBlock
                                Text="役割"
                                Style="{StaticResource EyebrowTextStyle}" />
                            <TextBlock
                                Text="このPCで行うことを選ぶ"
                                FontSize="22"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap" />

                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Style="{StaticResource InsetCardStyle}"
                                    Padding="0">
                                    <Grid>
                                        <Border
                                            Height="4"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource SenderAccentBrush}"
                                            CornerRadius="16,16,0,0" />

                                        <StackPanel Padding="20,18" Spacing="14">
                                            <StackPanel Spacing="10">
                                                <Border
                                                    Width="42"
                                                    Height="42"
                                                    CornerRadius="12"
                                                    Background="{StaticResource SenderAccentMutedBrush}">
                                                    <TextBlock
                                                        Text="↑"
                                                        FontSize="20"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource SenderAccentBrush}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Spacing="4">
                                                    <TextBlock
                                                        Text="音を送る"
                                                        FontSize="18"
                                                        FontWeight="SemiBold" />
                                                    <TextBlock
                                                        Text="{x:Bind ViewModel.SenderEntryDescription, Mode=OneWay}"
                                                        Style="{StaticResource BodyTextStyle}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <Button
                                                Content="送信側で開始"
                                                Click="OnStartSenderClick"
                                                IsEnabled="{x:Bind ViewModel.CanStartSender, Mode=OneWay}"
                                                Style="{StaticResource AccentButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                Padding="0,10" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource InsetCardStyle}"
                                    Padding="0">
                                    <Grid>
                                        <Border
                                            Height="4"
                                            VerticalAlignment="Top"
                                            Background="{StaticResource ListenerAccentBrush}"
                                            CornerRadius="16,16,0,0" />

                                        <StackPanel Padding="20,18" Spacing="14">
                                            <StackPanel Spacing="10">
                                                <Border
                                                    Width="42"
                                                    Height="42"
                                                    CornerRadius="12"
                                                    Background="{StaticResource ListenerAccentMutedBrush}">
                                                    <TextBlock
                                                        Text="↓"
                                                        FontSize="20"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource ListenerAccentBrush}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Spacing="4">
                                                    <TextBlock
                                                        Text="音を受け取る"
                                                        FontSize="18"
                                                        FontWeight="SemiBold" />
                                                    <TextBlock
                                                        Text="{x:Bind ViewModel.ListenerEntryDescription, Mode=OneWay}"
                                                        Style="{StaticResource BodyTextStyle}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <Button
                                                Content="受信側で開始"
                                                Click="OnStartListenerClick"
                                                IsEnabled="{x:Bind ViewModel.CanStartListener, Mode=OneWay}"
                                                HorizontalAlignment="Stretch"
                                                Padding="0,10" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════
                     Path diagnosing (transient)
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="PathDiagnosingCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="進行中"
                            Style="{StaticResource EyebrowTextStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.PathStepTitle, Mode=OneWay}"
                            FontSize="22"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{x:Bind ViewModel.PathStepDescription, Mode=OneWay}"
                            Style="{StaticResource BodyTextStyle}" />
                        <ProgressBar
                            IsIndeterminate="True"
                            Height="6" />
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 2a — Sender: share init payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="SenderShowInitCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{StaticResource SenderAccentMutedBrush}"
                                CornerRadius="8"
                                Padding="8,4">
                                <TextBlock
                                    Text="送信側"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource SenderAccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="接続コードを Android に貼り付ける"
                                FontSize="22"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="Windows 側で接続コードをコピーし、Android 側に貼り付けるだけで接続できます。応答は自動で戻るため、この画面では待機が基本です。"
                            Style="{StaticResource BodyTextStyle}" />
                        <Border Style="{StaticResource InsetCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="接続コード"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.CurrentConnectionCode, Mode=OneWay}"
                                    FontSize="18"
                                    FontFamily="Consolas"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True" />
                                <Button
                                    Content="接続コードをコピー"
                                    Click="OnCopyConnectionCodeClick"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />
                            </StackPanel>
                        </Border>
                        <TextBlock
                            Text="接続コードの有効期限は 10 分です。"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorAttentionBrush}" />

                        <Expander
                            x:Name="SenderManualFallbackExpander"
                            Header="従来の手動手順を使う"
                            Padding="0">
                            <Border
                                Style="{StaticResource InsetCardStyle}"
                                Margin="0,12,0,0">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        Text="接続コードを使わず、開始データと応答データを手動でやり取りする場合だけ使います。"
                                        Style="{StaticResource BodyTextStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button
                                            Content="開始データをコピー"
                                            Click="OnCopyPayloadClick"
                                            Padding="12,8" />
                                        <Button
                                            Content="クリップボードの応答データを使う"
                                            Click="OnPastePayloadClick"
                                            Padding="12,8" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="開始データ"
                                        Style="{StaticResource MetricLabelTextStyle}" />
                                    <Border
                                        Background="{ThemeResource AppSurfaceBrush}"
                                        CornerRadius="12"
                                        BorderBrush="{ThemeResource AppChromeStrokeBrush}"
                                        BorderThickness="1"
                                        Padding="12"
                                        MaxHeight="140">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.CurrentPayload, Mode=OneWay}"
                                                Style="{StaticResource CodeValueTextStyle}" />
                                        </ScrollViewer>
                                    </Border>
                                    <TextBlock
                                        Text="受け取った応答データ"
                                        Style="{StaticResource MetricLabelTextStyle}" />
                                    <TextBox
                                        x:Name="SenderConfirmPayloadInput"
                                        PlaceholderText="Android 側から受け取った応答データを貼り付ける"
                                        AcceptsReturn="True"
                                        Height="96"
                                        FontSize="12"
                                        FontFamily="Consolas" />
                                    <Button
                                        Content="この応答データで進める"
                                        Click="OnProcessSenderConfirmPayloadClick"
                                        HorizontalAlignment="Left"
                                        Padding="14,8" />
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 3a — Sender: verify code
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="SenderVerifyCodeCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{StaticResource SenderAccentMutedBrush}"
                                CornerRadius="8"
                                Padding="8,4">
                                <TextBlock
                                    Text="送信側"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource SenderAccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="6桁コードを確認"
                                FontSize="22"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="両端末に同じ番号が表示されていることを確認してください。"
                            Style="{StaticResource BodyTextStyle}" />

                        <Border
                            Style="{StaticResource InsetCardStyle}"
                            Padding="0,20"
                            HorizontalAlignment="Center"
                            MinWidth="280">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock
                                    Text="照合コード"
                                    Style="{StaticResource MetricLabelTextStyle}"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.VerificationCodeDisplay, Mode=OneWay}"
                                    FontSize="42"
                                    FontWeight="Black"
                                    FontFamily="Consolas"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                            <Button
                                Content="一致しているので接続する"
                                Click="OnApproveVerificationClick"
                                IsEnabled="{x:Bind ViewModel.CanApproveCode, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="20,10" />
                            <Button
                                Content="違うのでやり直す"
                                Click="OnRejectVerificationClick"
                                IsEnabled="{x:Bind ViewModel.CanRejectCode, Mode=OneWay}"
                                Padding="18,10" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 2b — Listener: receive init payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="ListenerScanInitCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{StaticResource ListenerAccentMutedBrush}"
                                CornerRadius="8"
                                Padding="8,4">
                                <TextBlock
                                    Text="受信側"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource ListenerAccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="開始データを貼り付ける"
                                FontSize="22"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="Windows または Android から受け取った開始データを、このPCに貼り付けてください。"
                            Style="{StaticResource BodyTextStyle}" />

                        <Border Style="{StaticResource InsetCardStyle}">
                            <StackPanel Spacing="12">
                                <Button
                                    Content="クリップボードの開始データを使う"
                                    Click="OnPastePayloadClick"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />
                                <TextBlock
                                    Text="手動入力"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBox
                                    x:Name="ListenerInitPayloadInput"
                                    PlaceholderText="開始データを貼り付ける"
                                    AcceptsReturn="True"
                                    Height="120"
                                    FontSize="12"
                                    FontFamily="Consolas" />
                                <Button
                                    Content="この開始データで進める"
                                    Click="OnProcessListenerInitPayloadClick"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 3b — Listener: share confirm payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="ListenerShowConfirmCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{StaticResource ListenerAccentMutedBrush}"
                                CornerRadius="8"
                                Padding="8,4">
                                <TextBlock
                                    Text="受信側"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource ListenerAccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="応答データを送信側へ共有する"
                                FontSize="22"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="応答データをコピーして送信側へ渡してください。6桁コードが一致すると接続が完了します。"
                            Style="{StaticResource BodyTextStyle}" />
                        <TextBlock
                            Text="応答データの有効期限は 10 分です。"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorAttentionBrush}" />

                        <Border
                            Style="{StaticResource InsetCardStyle}"
                            Padding="0,20"
                            HorizontalAlignment="Center"
                            MinWidth="280">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <TextBlock
                                    Text="照合コード"
                                    Style="{StaticResource MetricLabelTextStyle}"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.VerificationCodeDisplay, Mode=OneWay}"
                                    FontSize="38"
                                    FontWeight="Black"
                                    FontFamily="Consolas"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="送信側でも同じ番号が出ていれば接続できます。"
                                    Style="{StaticResource BodyTextStyle}"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InsetCardStyle}">
                            <StackPanel Spacing="12">
                                <Button
                                    Content="応答データをコピー"
                                    Click="OnCopyPayloadClick"
                                    HorizontalAlignment="Left"
                                    Padding="14,8" />
                                <TextBlock
                                    Text="応答データ"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <Border
                                    Background="{ThemeResource AppSurfaceBrush}"
                                    CornerRadius="12"
                                    BorderBrush="{ThemeResource AppChromeStrokeBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    MaxHeight="140">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.CurrentPayload, Mode=OneWay}"
                                            Style="{StaticResource CodeValueTextStyle}" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="UdpListenerWaitingCard"
                    Visibility="Collapsed"
                    Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{StaticResource ListenerAccentMutedBrush}"
                                CornerRadius="8"
                                Padding="8,4">
                                <TextBlock
                                    Text="受信側"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource ListenerAccentBrush}" />
                            </Border>
                            <TextBlock
                                Text="Android の音声を待っています"
                                FontSize="22"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="受信先情報は Android へ送信済みです。このまま最初の UDP + Opus パケット到着を待ってください。"
                            Style="{StaticResource BodyTextStyle}" />
                        <Border Style="{StaticResource InsetCardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Text="{x:Bind ViewModel.UdpReceiveLatencySummary, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.UdpReceiveLatencyDescription, Mode=OneWay}"
                                    Style="{StaticResource BodyTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Connection details (always available, collapsed)
                     ══════════════════════════════════════════ -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Expander
                        Header="接続の詳細"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                        <Grid Margin="0,16,0,0" RowSpacing="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel
                                x:Name="SessionIdPanel"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                Spacing="4">
                                <TextBlock
                                    Text="セッション ID"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.ActiveSessionId, Mode=OneWay}"
                                    Style="{StaticResource CodeValueTextStyle}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="1"
                                Spacing="6">
                                <TextBlock
                                    Text="接続経路"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.NetworkPathLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.CandidateCountLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.SelectedCandidatePairLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="2"
                                Spacing="6">
                                <TextBlock
                                    Text="音声ストリーム"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.AudioStreamSummaryLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.AudioBufferingLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.AudioHealthLabel, Mode=OneWay}"
                                    Style="{StaticResource MetricValueTextStyle}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="3"
                                Spacing="6">
                                <TextBlock
                                    Text="失敗診断"
                                    Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.FailureHintLabel, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.FailureCodeLabel, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Expander>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
