<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="P2PAudio.Windows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="音声リンク (Windows)">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Sticky header bar ═══ -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="32,14,32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock
                        Text="音声リンク"
                        FontSize="18"
                        FontWeight="Bold" />
                    <TextBlock
                        Text="{x:Bind ViewModel.TransportModeLabel, Mode=OneWay}"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.BackendLabel, Mode=OneWay}"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Content="⏹ 終了"
                    Click="OnStopClick"
                    IsEnabled="{x:Bind ViewModel.CanStop, Mode=OneWay}"
                    Padding="16,7"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ═══ Scrollable content ═══ -->
        <ScrollViewer Grid.Row="1" Padding="32,20,32,32" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="880">

                <!-- ── Status hero ── -->
                <Border
                    x:Name="StatusHeroCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind ViewModel.StreamStateIndicator, Mode=OneWay}"
                                    FontSize="26"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="StreamStateText"
                                    Text="{x:Bind ViewModel.StreamStateLabel, Mode=OneWay}"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                            <Border
                                Grid.Column="2"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="10"
                                Padding="10,4"
                                VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind ViewModel.StepProgressLabel, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ProgressBar
                            Minimum="0"
                            Maximum="3"
                            Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                            Height="4"
                            Margin="0,2,0,0" />

                        <TextBlock
                            Text="{x:Bind ViewModel.RecommendedAction, Mode=OneWay}"
                            FontSize="15"
                            FontWeight="SemiBold"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            FontSize="13"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <StackPanel
                            x:Name="StatusFailurePanel"
                            Visibility="Collapsed"
                            Spacing="2"
                            Margin="0,4,0,0">
                            <TextBlock
                                Text="{x:Bind ViewModel.FailureHintLabel, Mode=OneWay}"
                                FontSize="13"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FailureCodeLabel, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Transient toast ── -->
                <InfoBar
                    x:Name="TransientInfoBar"
                    IsOpen="False"
                    Severity="Success"
                    IsClosable="True" />

                <!-- ══════════════════════════════════════════
                     Step 1 — Role selection (Entry)
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="EntryCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Text="転送モードと、このPCの役割を選んでください"
                            FontSize="16"
                            FontWeight="SemiBold" />
                        <StackPanel Spacing="6">
                            <TextBlock
                                Text="転送モード"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox
                                x:Name="TransportModeComboBox"
                                SelectionChanged="OnTransportModeSelectionChanged"
                                SelectedIndex="{x:Bind ViewModel.SelectedTransportModeIndex, Mode=OneWay}">
                                <ComboBoxItem Content="WebRTC" />
                                <ComboBoxItem Content="UDP + Opus" />
                            </ComboBox>
                            <TextBlock
                                Text="{x:Bind ViewModel.TransportModeDescription, Mode=OneWay}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Sender card -->
                            <Border
                                Grid.Column="0"
                                Background="#1A2535"
                                CornerRadius="12"
                                BorderBrush="#4C74A8"
                                BorderThickness="1"
                                Padding="18,16">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Text="🔊"
                                        FontSize="28"
                                        Foreground="#8CC7FF" />
                                    <TextBlock
                                        Text="音を送る"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="#F4F8FF" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.SenderEntryDescription, Mode=OneWay}"
                                        FontSize="12"
                                        Foreground="#C3D4E9"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Content="送信側で開始"
                                        Click="OnStartSenderClick"
                                        IsEnabled="{x:Bind ViewModel.CanStartSender, Mode=OneWay}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,9"
                                        Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Listener card -->
                            <Border
                                Grid.Column="1"
                                Background="#33261C"
                                CornerRadius="12"
                                BorderBrush="#C58E43"
                                BorderThickness="1"
                                Padding="18,16">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Text="🎧"
                                        FontSize="28"
                                        Foreground="#FFD39A" />
                                    <TextBlock
                                        Text="音を受け取る"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="#FFF4E4" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.ListenerEntryDescription, Mode=OneWay}"
                                        FontSize="12"
                                        Foreground="#E4D0BC"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Content="受信側で開始"
                                        Click="OnStartListenerClick"
                                        IsEnabled="{x:Bind ViewModel.CanStartListener, Mode=OneWay}"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,9"
                                        Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Path diagnosing (transient)
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="PathDiagnosingCard"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="10">
                        <TextBlock
                            Text="{x:Bind ViewModel.PathStepTitle, Mode=OneWay}"
                            FontSize="16"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{x:Bind ViewModel.PathStepDescription, Mode=OneWay}"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <ProgressBar IsIndeterminate="True" Height="4" />
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 2a — Sender: share init payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="SenderShowInitCard"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#E8F0FE" CornerRadius="8" Padding="7,3">
                                <TextBlock Text="送信側" FontSize="11" FontWeight="Bold" Foreground="#1A56DB" />
                            </Border>
                            <TextBlock
                                Text="接続コードを Android に貼り付ける"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="Windows 側で接続コードをコピーし、Android 側に貼り付けるだけで接続できます。応答は自動で戻るので、通常はこの画面で待つだけです。"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="⏱ 接続コードの有効期限は 10 分です"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorAttentionBrush}" />

                        <StackPanel Spacing="8">
                            <Button Content="接続コードをコピー" Click="OnCopyConnectionCodeClick" Padding="12,6" />
                            <TextBlock Text="接続コード" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                            <Border
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="12">
                                <TextBlock
                                    Text="{x:Bind ViewModel.CurrentConnectionCode, Mode=OneWay}"
                                    FontSize="15"
                                    FontFamily="Consolas"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True" />
                            </Border>
                        </StackPanel>

                        <Expander x:Name="SenderManualFallbackExpander" Header="従来の手動手順を使う" Padding="0">
                            <StackPanel Spacing="10" Margin="0,10,0,0">
                                <TextBlock
                                    Text="接続コードを使わず、開始データと応答データを手動でやり取りする場合のみ使います。"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="開始データをコピー" Click="OnCopyPayloadClick" Padding="12,6" />
                                    <Button Content="クリップボードの応答データを使う" Click="OnPastePayloadClick" Padding="12,6" />
                                </StackPanel>
                                <TextBlock Text="開始データ" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                                <Border
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    MaxHeight="120">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.CurrentPayload, Mode=OneWay}"
                                            FontSize="11"
                                            FontFamily="Consolas"
                                            TextWrapping="Wrap"
                                            IsTextSelectionEnabled="True" />
                                    </ScrollViewer>
                                </Border>
                                <TextBlock Text="受け取った応答データ" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                                <TextBox
                                    x:Name="SenderConfirmPayloadInput"
                                    PlaceholderText="Android 側から受け取った応答データを貼り付ける"
                                    AcceptsReturn="True"
                                    Height="80"
                                    FontSize="11"
                                    FontFamily="Consolas" />
                                <Button Content="この応答データで進める" Click="OnProcessSenderConfirmPayloadClick" Padding="12,6" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 3a — Sender: verify code
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="SenderVerifyCodeCard"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#E8F0FE" CornerRadius="8" Padding="7,3">
                                <TextBlock Text="送信側" FontSize="11" FontWeight="Bold" Foreground="#1A56DB" />
                            </Border>
                            <TextBlock
                                Text="6桁コードを確認"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="両端末に同じ番号が表示されていることを確認してください。"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />

                        <Border
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="12"
                            Padding="0,16"
                            Margin="0,4"
                            HorizontalAlignment="Center"
                            MinWidth="240">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock
                                    Text="照合コード"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.VerificationCodeDisplay, Mode=OneWay}"
                                    FontSize="40"
                                    FontWeight="Black"
                                    FontFamily="Consolas"
                                    HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <Button
                                Content="✅ 一致 — 接続する"
                                Click="OnApproveVerificationClick"
                                IsEnabled="{x:Bind ViewModel.CanApproveCode, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="20,10" />
                            <Button
                                Content="違う — やり直す"
                                Click="OnRejectVerificationClick"
                                IsEnabled="{x:Bind ViewModel.CanRejectCode, Mode=OneWay}"
                                Padding="16,10" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 2b — Listener: receive init payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="ListenerScanInitCard"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#FEF0E0" CornerRadius="8" Padding="7,3">
                                <TextBlock Text="受信側" FontSize="11" FontWeight="Bold" Foreground="#B45309" />
                            </Border>
                            <TextBlock
                                Text="開始データを貼り付ける"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="Windows または Android から受け取った開始データを、このPCに貼り付けてください。"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />

                        <Expander Header="手動で操作する" Padding="0">
                            <StackPanel Spacing="10" Margin="0,10,0,0">
                                <Button Content="クリップボードの開始データを使う" Click="OnPastePayloadClick" Padding="12,6" />
                                <TextBlock Text="手動入力" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                                <TextBox
                                    x:Name="ListenerInitPayloadInput"
                                    PlaceholderText="開始データを貼り付ける"
                                    AcceptsReturn="True"
                                    Height="80"
                                    FontSize="11"
                                    FontFamily="Consolas" />
                                <Button Content="この開始データで進める" Click="OnProcessListenerInitPayloadClick" Padding="12,6" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Step 3b — Listener: share confirm payload
                     ══════════════════════════════════════════ -->
                <Border
                    x:Name="ListenerShowConfirmCard"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="28,22">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#FEF0E0" CornerRadius="8" Padding="7,3">
                                <TextBlock Text="受信側" FontSize="11" FontWeight="Bold" Foreground="#B45309" />
                            </Border>
                            <TextBlock
                                Text="応答データを送信側へ共有する"
                                FontSize="16"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock
                            Text="応答データをコピーして送信側へ渡してください。6桁コードが一致すると接続が完了します。"
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="⏱ 応答データの有効期限は 10 分です"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorAttentionBrush}" />

                        <StackPanel Margin="0,4" Spacing="12">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="12"
                                Padding="0,16"
                                HorizontalAlignment="Center"
                                MinWidth="240">
                                <StackPanel HorizontalAlignment="Center" Spacing="4">
                                    <TextBlock
                                        Text="照合コード"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Center" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.VerificationCodeDisplay, Mode=OneWay}"
                                        FontSize="36"
                                        FontWeight="Black"
                                        FontFamily="Consolas"
                                        HorizontalAlignment="Center" />
                                    <TextBlock
                                        Text="送信側でもこの番号が表示されていれば OK"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"
                                        HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Expander Header="手動で操作する" Padding="0">
                            <StackPanel Spacing="10" Margin="0,10,0,0">
                                <Button Content="応答データをコピー" Click="OnCopyPayloadClick" Padding="12,6" />
                                <TextBlock Text="応答データ" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontWeight="SemiBold" />
                                <Border
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    MaxHeight="120">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.CurrentPayload, Mode=OneWay}"
                                            FontSize="11"
                                            FontFamily="Consolas"
                                            TextWrapping="Wrap"
                                            IsTextSelectionEnabled="True" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════
                     Connection details (always available, collapsed)
                     ══════════════════════════════════════════ -->
                <Expander
                    Header="接続の詳細"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Margin="0,4,0,0">
                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <StackPanel
                            x:Name="SessionIdPanel"
                            Visibility="Collapsed"
                            Spacing="2">
                            <TextBlock Text="セッションID" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ActiveSessionId, Mode=OneWay}"
                                FontSize="12"
                                FontFamily="Consolas"
                                IsTextSelectionEnabled="True" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.NetworkPathLabel, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CandidateCountLabel, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.SelectedCandidatePairLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.FailureHintLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{x:Bind ViewModel.FailureCodeLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="音声ストリーム"
                            FontSize="11"
                            Margin="0,8,0,0"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.AudioStreamSummaryLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{x:Bind ViewModel.AudioBufferingLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Text="{x:Bind ViewModel.AudioHealthLabel, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
