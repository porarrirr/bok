<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="P2PAudio.Windows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="P2P Audio (Windows)">
    <Grid Padding="20" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                Text="P2P Audio - Windows"
                FontSize="26"
                FontWeight="Bold" />
            <TextBlock Text="{x:Bind ViewModel.BackendLabel, Mode=OneWay}" Opacity="0.7" />
            <TextBlock Text="{x:Bind ViewModel.FlowStateLabel, Mode=OneWay}" Opacity="0.7" />
            <TextBlock Text="{x:Bind ViewModel.StreamStateLabel, Mode=OneWay}" Opacity="0.7" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="6">
            <TextBlock Text="Status" FontWeight="SemiBold" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.NetworkPathLabel, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.CandidateCountLabel, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.SelectedCandidatePairLabel, Mode=OneWay}" />
            <TextBlock Text="{x:Bind ViewModel.FailureHintLabel, Mode=OneWay}" Foreground="IndianRed" />
            <TextBlock Text="{x:Bind ViewModel.FailureCodeLabel, Mode=OneWay}" Foreground="IndianRed" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,12,0,0" Orientation="Horizontal" Spacing="8">
            <Button Content="Start Sender" Click="OnStartSenderClick" />
            <Button Content="Start Listener" Click="OnStartListenerClick" />
            <Button Content="Process Payload" Click="OnProcessPayloadClick" />
            <Button Content="Paste Payload" Click="OnPastePayloadClick" />
            <Button Content="Scan QR (Camera)" Click="OnScanFromCameraClick" />
            <Button Content="Approve Code" Click="OnApproveVerificationClick" />
            <Button Content="Reject Code" Click="OnRejectVerificationClick" />
            <Button Content="Stop" Click="OnStopClick" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,12,0,0" Spacing="6">
            <TextBlock Text="Init/Confirm Payload" FontWeight="SemiBold" />
            <TextBox Text="{x:Bind ViewModel.CurrentPayload, Mode=TwoWay}" AcceptsReturn="True" Height="120" />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,4,0,0" Spacing="6">
            <TextBlock Text="{x:Bind ViewModel.ActiveSessionId, Mode=OneWay}" Opacity="0.75" />
            <TextBlock Text="{x:Bind ViewModel.VerificationCode, Mode=OneWay}" FontSize="24" FontWeight="Bold" />
        </StackPanel>

        <StackPanel
            Grid.Row="5"
            Margin="0,12,0,0"
            Spacing="8">
            <Image
                Source="{x:Bind ViewModel.PayloadQrImage, Mode=OneWay}"
                Width="240"
                Height="240"
                Stretch="Uniform" />
            <TextBlock
                TextWrapping="Wrap"
                Foreground="Gray"
                Text="This shell runs v2 payload flow and can scan/paste QR payloads. Native WebRTC runtime is required by default; use ALLOW_STUB_FOR_DEV=1 only for development fallback." />
        </StackPanel>
    </Grid>
</Window>
