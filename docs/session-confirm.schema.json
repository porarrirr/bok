{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/p2p-audio/session-confirm.schema.json",
  "title": "PairingConfirmPayload",
  "type": "object",
  "required": [
    "version",
    "phase",
    "sessionId",
    "receiverDeviceName",
    "receiverPubKeyFingerprint",
    "answerSdp",
    "expiresAtUnixMs"
  ],
  "properties": {
    "version": { "const": "2" },
    "phase": { "const": "confirm" },
    "sessionId": { "type": "string", "minLength": 1 },
    "receiverDeviceName": { "type": "string", "minLength": 1 },
    "receiverPubKeyFingerprint": { "type": "string", "minLength": 1 },
    "answerSdp": { "type": "string", "minLength": 1 },
    "expiresAtUnixMs": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
