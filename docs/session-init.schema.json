{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/p2p-audio/session-init.schema.json",
  "title": "PairingInitPayload",
  "type": "object",
  "required": [
    "version",
    "phase",
    "sessionId",
    "senderDeviceName",
    "senderPubKeyFingerprint",
    "offerSdp",
    "expiresAtUnixMs"
  ],
  "properties": {
    "version": { "const": "2" },
    "phase": { "const": "init" },
    "sessionId": { "type": "string", "minLength": 1 },
    "senderDeviceName": { "type": "string", "minLength": 1 },
    "senderPubKeyFingerprint": { "type": "string", "minLength": 1 },
    "offerSdp": { "type": "string", "minLength": 1 },
    "expiresAtUnixMs": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
